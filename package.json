{
  "name": "peblo-project",
  "private": true,
  "scripts": {
    "dev:api": "bun run --cwd apps/backend src/index.ts",
    "dev:worker": "bun run --cwd apps/server worker",
    "dev:web": "bun run --cwd apps/frontend dev",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.14",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
